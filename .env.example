# Server
API_ADDR=:8080

# PostgreSQL (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Aiven Kafka (console.aiven.io → Service Overview)
KAFKA_BROKERS=your-service-name.aivencloud.com:YOUR_PORT
KAFKA_TOPIC_JOBS=jobs
# Aiven uses TLS certificate authentication (download from Aiven Console).
# Default filenames work when cwd is repo root. From backend/, use ../service.cert etc.
KAFKA_CERT_FILE=service.cert
KAFKA_KEY_FILE=service.key
KAFKA_CA_FILE=ca.pem
KAFKA_CONSUMER_GROUP=flowbit-workers

# Optional behavior
APPLY_MIGRATIONS=true
