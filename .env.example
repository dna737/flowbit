# Server
API_ADDR=:8080

# PostgreSQL (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Redpanda Cloud (cloud.redpanda.com → Cluster → Overview → Bootstrap servers)
KAFKA_BROKERS=your-seed-broker.cloud.redpanda.com:9092
KAFKA_TOPIC_JOBS=jobs
# Redpanda Cloud → Security → Users — create a user and copy credentials
KAFKA_USERNAME=your-redpanda-username
KAFKA_PASSWORD=your-redpanda-password
KAFKA_CONSUMER_GROUP=flowbit-workers
# TLS to Kafka brokers (default true; use false only for local plaintext brokers)
KAFKA_USE_TLS=true

# Optional behavior
APPLY_MIGRATIONS=true
