# Server
API_ADDR=:8080

# PostgreSQL (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Upstash Kafka
KAFKA_BROKERS=your-kafka-broker-1:9092,your-kafka-broker-2:9092
KAFKA_TOPIC_JOBS=jobs
KAFKA_USERNAME=your-kafka-username
KAFKA_PASSWORD=your-kafka-password
KAFKA_CONSUMER_GROUP=flowbit-workers
# TLS to Kafka brokers (default true; use false only for local plaintext brokers)
KAFKA_USE_TLS=true

# Upstash Redis (required only for Block 1: `go run ./cmd/smoke`. API and worker do not use Redis.)
REDIS_URL=redis://default:password@host:6379/0

# Optional behavior
APPLY_MIGRATIONS=true
