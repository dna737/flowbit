# Server
API_ADDR=:8080
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Aiven Kafka (console.aiven.io → Service Overview)
KAFKA_BROKERS=your-service-name.aivencloud.com:YOUR_PORT
KAFKA_TOPIC_JOBS=jobs
# Aiven TLS certificate authentication (download from Aiven Console → Kafka → Connection info).
# Required for Aiven. Leave blank (or omit) to disable TLS for local Kafka.
# Default paths below work when cwd is repo root; from backend/ use ../service.cert etc.
KAFKA_CERT_FILE=service.cert
KAFKA_KEY_FILE=service.key
KAFKA_CA_FILE=ca.pem
KAFKA_CONSUMER_GROUP=flowbit-workers

# Optional behavior
# When true, cmd/smoke and app startup apply embedded schema; smoke also checks jobs + dead_letter_queue exist.
APPLY_MIGRATIONS=true

# Gemini AI dispatcher (POST /dispatch). Leave GEMINI_API_KEY blank to disable.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# Comma-separated fallback models tried on 5xx/429 from the primary (in order).
GEMINI_MODEL_FALLBACKS=gemini-flash-latest,gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite
